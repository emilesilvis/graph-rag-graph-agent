# Copy to `.env` and fill in.

# OpenAI
OPENAI_API_KEY=sk-...
AGENT_MODEL=gpt-4o-mini
JUDGE_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# Neo4j (local running instance)
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# --- Knowledge source (all optional; defaults point at ./knowledge_sources) --
# Swap these to evaluate the two agents on a different corpus without any
# code changes. Relative paths are resolved against the project root.
# KNOWLEDGE_DIR=./knowledge_sources
# GRAPH_CYPHER_PATH=./knowledge_sources/graph.cypher
# CHROMA_DIR=./.chroma
# CHROMA_COLLECTION=knowledge-corpus

# --- Optional tuning knobs -------------------------------------------------
# One-line description of the corpus; injected symmetrically into both
# agents' persona. Leave unset for a fully domain-neutral run.
# DOMAIN_DESCRIPTION="Medical device regulatory documents"
#
# Comma-separated list of exact entity names to exclude from eval question
# generation (shape heuristics already drop slug/env-var-shaped names).
# EVAL_ENTITY_BLOCKLIST=Foo,Bar
